      propertyPath: 'dialogue1.Array.data[0]'
      value: Thank you! I'm looking forward to eating this. Anyway...
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: 'dialogue1.Array.data[1]'
      value: The Governor despises peasants who attempt to overthrow his rule.
      objectReference: {fileID: 0}
