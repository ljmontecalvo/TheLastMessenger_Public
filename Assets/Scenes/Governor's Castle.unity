    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: enableMovement
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: prerequisteItem
      value: 
      objectReference: {fileID: 910062634}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: tamperedContent
      value: We shall halt all preparations for rebellion at this time. I have reason
        to believe that the Governor is going to equally distribute food amongst
        the people during the famine.
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: dialogueSetCount
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: oneAndDoneDirection
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: transactionDialogue
      value: I found this letter on the ground the other day, you should take it
        and deliver it to him.
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
