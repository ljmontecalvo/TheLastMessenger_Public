--- !u!1001 &927075898
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: title
      value: Plan to [redacted] the Governor's castle.
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: content
      value: I have reason to believe the Governor is stockpilling food for the upcoming
        famine. In 3 days we shall meet to burn the Governor's castle and rid the
        state of his reign once and for all.
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: npcName
      value: Dungeon Worker
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: objective
      value: Deliver this message from a Rebellion Member to the Rebellion Leader
        in Rolling Meadows.
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: oneAndDone
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: senderName
      value: Jacob Thorn
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: enableLetter
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: receiverName
      value: Rebellion Leader
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
      propertyPath: startAlerted
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2913163817265418663, guid: f26c40c74954afb4d9de004927a5ba54, type: 3}
